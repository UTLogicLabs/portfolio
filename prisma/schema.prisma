generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  runtime  = "workerd"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
