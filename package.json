{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Personal portfolio site — React Router v7 on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "react-router build",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "wrangler types && react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate:init": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script --output migration.sql && wrangler d1 execute portfolio-db --local --file=migration.sql && rm -f migration.sql",
    "db:migrate:local": "node scripts/migrate.js",
    "db:migrate:remote": "node scripts/migrate.js --remote",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UTLogicLabs/portfolio.git"
  },
  "keywords": [],
  "author": "Joshua Dix <josh.dix@theblindman.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/UTLogicLabs/portfolio/issues"
  },
  "homepage": "https://github.com/UTLogicLabs/portfolio#readme",
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.20",
    "isbot": "^5.1.43",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.9.6",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.15.3",
    "@cloudflare/workers-types": "^4.20260621.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "^7.9.6",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.3.5",
    "vite-plugin-icons-spritesheet": "^3.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.88.0"
  }
}
